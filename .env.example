PORT=4000
NODE_ENV=development

OPENSEARCH_NODE=http://localhost:9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_INDEX=legal_documents
OPENSEARCH_TLS_REJECT_UNAUTHORIZED=true

